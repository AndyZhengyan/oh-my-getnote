{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "web",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["lib/**/*"],
  "exclude": ["node_modules", "web", "notes", "data", "source", "docs", "kg-site", "images", "scripts", "dist/**/*", "lib/linker/**/*"]
}
