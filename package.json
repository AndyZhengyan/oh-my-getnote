{
  "name": "oh-my-getnote",
  "description": "Oh My Getnote — AI-powered personal Memex inspired by Vannevar Bush",
  "version": "0.1.1",
  "author": "Andy Zhengyan",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndyZhengyan/oh-my-getnote.git"
  },
  "license": "MIT",
  "keywords": [
    "knowledge-graph",
    "vector-search",
    "nextjs",
    "ai",
    "notes",
    "memex",
    "llm-wiki"
  ],
  "bugs": {
    "url": "https://github.com/AndyZhengyan/oh-my-getnote/issues"
  },
  "homepage": "https://github.com/AndyZhengyan/oh-my-getnote#readme",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix web",
    "dev": "npm run dev --prefix web",
    "test": "cd web && npx vitest run",
    "test:watch": "cd web && npx vitest",
    "lint": "cd web && npx eslint .",
    "build": "cd web && npx next build",
    "typecheck": "cd web && npx tsc --noEmit",
    "backfill": "npx tsx scripts/backfill.ts",
    "convert": "npx tsc && npx tsx tools/convert.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "cheerio": "^1.2.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
